+
+struct LanguageOffset {
+  const wchar_t* language;
+  int offset;
+};
+
+constexpr LanguageOffset kLanguages[] = {
+#define HANDLE_LANGUAGE(language, offset) {L## #language, offset},
+    DO_LANGUAGES
+#undef HANDLE_LANGUAGE
+};
+
+std::wstring ToLowerASCII(std::wstring_view value) {
+  std::wstring result(value);
+  for (wchar_t& character : result) {
+    if (character >= L'A' && character <= L'Z') {
+      character += L'a' - L'A';
+    }
+  }
+  return result;
+}
+
+int FindExactLanguageOffset(std::wstring_view language) {
+  for (const auto& entry : kLanguages) {
+    if (language == entry.language) {
+      return entry.offset;
+    }
+  }
+  return -1;
+}
+
+bool IsLanguageOrVariant(std::wstring_view language,
+                         std::wstring_view base_language) {
+  return language == base_language ||
+         (language.size() > base_language.size() &&
+          language.substr(0, base_language.size()) == base_language &&
+          language[base_language.size()] == L'-');
+}
+
+int FindAliasedLanguageOffset(std::wstring_view language) {
+  if (IsLanguageOrVariant(language, L"sr-latn")) {
+    return FindExactLanguageOffset(L"sr-latn");
+  }
+  if (IsLanguageOrVariant(language, L"sr-cyrl")) {
+    return FindExactLanguageOffset(L"sr");
+  }
+  if (IsLanguageOrVariant(language, L"zh-hans") ||
+      IsLanguageOrVariant(language, L"zh-chs")) {
+    return FindExactLanguageOffset(L"zh-cn");
+  }
+  if (IsLanguageOrVariant(language, L"zh-hant") ||
+      IsLanguageOrVariant(language, L"zh-cht")) {
+    return FindExactLanguageOffset(L"zh-tw");
+  }
+  if (language == L"en-au" || language == L"en-ca" || language == L"en-nz" ||
+      language == L"en-za") {
+    return FindExactLanguageOffset(L"en-gb");
+  }
+  if (language == L"es-es") {
+    return FindExactLanguageOffset(L"es");
+  }
+  if (language == L"he" || language == L"iw") {
+    return FindExactLanguageOffset(L"iw");
+  }
+  if (language == L"nb" || language == L"nn" || language == L"no") {
+    return FindExactLanguageOffset(L"no");
+  }
+  if (language == L"tl" || language == L"fil") {
+    return FindExactLanguageOffset(L"fil");
+  }
+  if (language == L"zh-chs" || language == L"zh-hans" || language == L"zh-sg") {
+    return FindExactLanguageOffset(L"zh-cn");
+  }
+  if (language == L"zh-cht" || language == L"zh-hant" || language == L"zh-hk" ||
+      language == L"zh-mo") {
+    return FindExactLanguageOffset(L"zh-tw");
+  }
+  return -1;
+}
+
+int FindCompatibleNeutralLanguageOffset(std::wstring_view language) {
+  if (language == L"en") {
+    return FindExactLanguageOffset(L"en-us");
+  }
+  if (language == L"es") {
+    return FindExactLanguageOffset(L"es-419");
+  }
+  if (language == L"pt") {
+    return FindExactLanguageOffset(L"pt-br");
+  }
+  if (language == L"zh") {
+    return FindExactLanguageOffset(L"zh-cn");
+  }
+  return FindAliasedLanguageOffset(language);
+}
+
+std::vector<std::wstring> GetPreferredUILanguages() {
+  std::vector<std::wstring> languages;
+  constexpr DWORD kLanguageFlags =
+      MUI_LANGUAGE_NAME | MUI_MERGE_SYSTEM_FALLBACK | MUI_MERGE_USER_FALLBACK;
+  ULONG language_count = 0;
+  ULONG buffer_size = 0;
+  if (GetThreadPreferredUILanguages(kLanguageFlags, &language_count, nullptr,
+                                    &buffer_size) &&
+      buffer_size > 1) {
+    std::vector<wchar_t> buffer(buffer_size);
+    if (GetThreadPreferredUILanguages(kLanguageFlags, &language_count,
+                                      buffer.data(), &buffer_size)) {
+      std::wstring_view remaining(buffer.data(), buffer.size());
+      while (!remaining.empty() && remaining.front() != L'\0') {
+        const size_t terminator = remaining.find(L'\0');
+        if (terminator == std::wstring_view::npos) {
+          break;
+        }
+        languages.emplace_back(remaining.substr(0, terminator));
+        remaining.remove_prefix(terminator + 1);
+      }
+    }
+  }
+
+  if (languages.empty()) {
+    wchar_t locale_name[LOCALE_NAME_MAX_LENGTH] = {};
+    if (GetUserDefaultLocaleName(locale_name, LOCALE_NAME_MAX_LENGTH)) {
+      languages.emplace_back(locale_name);
+    }
+  }
+  return languages;
+}
+
+}  // namespace
+
+int GetInstallerLanguageOffset() {
+  const std::vector<std::wstring> candidates = GetPreferredUILanguages();
+
+  for (const std::wstring& candidate : candidates) {
+    const std::wstring language = ToLowerASCII(candidate);
+    int offset = FindExactLanguageOffset(language);
+    if (offset < 0) {
+      offset = FindAliasedLanguageOffset(language);
+    }
+    if (offset >= 0) {
+      return offset;
+    }
+  }
+
+  for (const std::wstring& candidate : candidates) {
+    const std::wstring language = ToLowerASCII(candidate);
+    const std::wstring_view neutral_language =
+        std::wstring_view(language).substr(0, language.find(L'-'));
+    int offset = FindCompatibleNeutralLanguageOffset(neutral_language);
+    if (offset < 0) {
+      offset = FindExactLanguageOffset(neutral_language);
+    }
+    if (offset >= 0) {
+      return offset;
+    }
+  }
+
+  const int fallback = FindExactLanguageOffset(L"en-us");
+  return fallback >= 0 ? fallback : 0;
+}
+
+std::wstring GetInstallerLocalizedString(HMODULE module,
+                                         int base_message_id,
+                                         int language_offset) {
+  wchar_t* resource = nullptr;
+  const int length = LoadStringW(module, base_message_id + language_offset,
+                                 reinterpret_cast<wchar_t*>(&resource), 0);
+  if (length > 0) {
+    return std::wstring(resource, length);
+  }
+
+  const int fallback_offset = FindExactLanguageOffset(L"en-us");
+  if (fallback_offset >= 0 && fallback_offset != language_offset) {
+    resource = nullptr;
+    const int fallback_length =
+        LoadStringW(module, base_message_id + fallback_offset,
+                    reinterpret_cast<wchar_t*>(&resource), 0);
+    if (fallback_length > 0) {
+      return std::wstring(resource, fallback_length);
+    }
+  }
+  return std::wstring();
+}
+
+std::wstring FormatInstallerLocalizedString(HMODULE module,
+                                            int base_message_id,
+                                            int language_offset,
+                                            std::wstring_view replacement) {
+  std::wstring result =
+      GetInstallerLocalizedString(module, base_message_id, language_offset);
+  constexpr std::wstring_view kPlaceholder = L"$1";
+  size_t position = 0;
+  while ((position = result.find(kPlaceholder, position)) !=
+         std::wstring::npos) {
+    result.replace(position, kPlaceholder.size(), replacement);
+    position += replacement.size();
+  }
+  return result;
+}
+
+void ShowUnsupportedProcessorError(HMODULE module) {
+  const int language_offset = GetInstallerLanguageOffset();
+  const std::wstring title = GetInstallerLocalizedString(
+      module, IDS_MINI_INSTALLER_ERROR_TITLE_BASE, language_offset);
+  const std::wstring message = FormatInstallerLocalizedString(
+      module, IDS_INSTALL_CPU_NOT_SUPPORTED_BASE, language_offset,
+      kProductName);
+  MessageBoxW(nullptr, message.c_str(), title.c_str(),
+              MB_OK | MB_ICONERROR | MB_SETFOREGROUND);
+}
+
+}  // namespace mini_installer
