+ public:
+  ThoriumAuthorsDataSource() {}
+  ThoriumAuthorsDataSource(const ThoriumAuthorsDataSource&) = delete;
+  ThoriumAuthorsDataSource& operator=(const ThoriumAuthorsDataSource&) = delete;
+  std::string GetSource() override;
