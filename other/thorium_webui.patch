+  std::string GetContentSecurityPolicy(
+      network::mojom::CSPDirectiveName directive) override;
+  void StartDataRequest(const GURL& url,
+                        const content::WebContents::Getter& wc_getter,
+                        GotDataCallback callback) override;
+};
+
+std::string ThoriumAuthorsDataSource::GetSource() {
+  return chrome::kChromeUIAuthorsHost;
+}
+
+std::string ThoriumAuthorsDataSource::GetMimeType(const GURL& url) {
+  return "text/html";
+}
+
+std::string ThoriumAuthorsDataSource::GetContentSecurityPolicy(
+    network::mojom::CSPDirectiveName directive) {
+  if (directive == network::mojom::CSPDirectiveName::ScriptSrc)
+    return "script-src 'unsafe-inline'";
+  return std::string();
+}
+
+void ThoriumAuthorsDataSource::StartDataRequest(
+    const GURL& url,
+    const content::WebContents::Getter& wc_getter,
+    GotDataCallback callback) {
+  std::string authors = base::EscapeForHTML(
+      ui::ResourceBundle::GetSharedInstance().LoadDataResourceString(
+          IDR_WEBUI_IMAGES_AUTHORS_TXT));
+  std::string source = R"(
+      <html>
+      <head>
+        <title>Thorium Authors</title>
+        <meta charset="utf-8">
+        <meta name="color-scheme" content="light dark">
+        <meta name="viewport" content="width=device-width, initial-scale=1">
+        <link rel="shortcut icon" type="image/x-icon" href="chrome://theme/current-channel-logo@2x">
+        <style>
+          @import url(chrome://resources/css/text_defaults_md.css);
+          body { margin: 0; }
+          main { box-sizing: border-box; max-width: 980px; margin: 0 auto; padding: 32px 24px 48px; }
+          h1 { font-size: 28px; font-weight: 500; margin: 0 0 18px; }
+          pre {
+            box-sizing: border-box;
+            margin: 0;
+            padding: 20px;
+            overflow: auto;
+            white-space: pre-wrap;
+            word-break: break-word;
+            border: 1px solid color-mix(in srgb, currentColor 16%, transparent);
+            border-radius: 8px;
+            font: 13px/1.55 ui-monospace, SFMono-Regular, Consolas, "Liberation Mono", monospace;
+          }
+        </style>
+      </head>
+      <body>
+        <main>
+          <h1>Thorium Authors</h1>
+          <pre>)" + authors + R"(</pre>
+        </main>
+      </body>
+      </html>
+    )";
+  std::move(callback).Run(
+      base::MakeRefCounted<base::RefCountedString>(std::move(source)));
+}
+
+class ThoriumAuthorsUI;
+class ThoriumAuthorsUIConfig : public content::DefaultWebUIConfig<ThoriumAuthorsUI> {
+  public:
+   ThoriumAuthorsUIConfig() : DefaultWebUIConfig("chrome", chrome::kChromeUIAuthorsHost) {}
+};
+
+class ThoriumAuthorsUI : public content::WebUIController {
+ public:
+  ThoriumAuthorsUI(content::WebUI* web_ui) : content::WebUIController(web_ui) {
+    content::URLDataSource::Add(Profile::FromWebUI(web_ui), std::make_unique<ThoriumAuthorsDataSource>());
+  }
+  ThoriumAuthorsUI(const ThoriumAuthorsUI&) = delete;
+  ThoriumAuthorsUI& operator=(const ThoriumAuthorsUI&) = delete;
+};
+
+#endif  // THORIUM_EASTER_EGGS_H_
