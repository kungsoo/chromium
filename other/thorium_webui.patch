+  void StartDataRequest(const GURL& url,
+                        const content::WebContents::Getter& wc_getter,
+                        GotDataCallback callback) override;
+};
+
+std::string ThoriumRobotDataSource::GetSource() {
+  return chrome::kChromeUIRobotHost;
+}
+
+std::string ThoriumRobotDataSource::GetMimeType(const GURL& url) {
+  return "text/html";
+}
+
+void ThoriumRobotDataSource::StartDataRequest(
+    const GURL& url,
+    const content::WebContents::Getter& wc_getter,
+    GotDataCallback callback) {
+  std::string source = R"(
+      <html>
+      <head>
+        <title>Thorium Robot</title>
+        <meta name="color-scheme" content="light dark">
+        <meta name="viewport" content="width=device-width, initial-scale=1">
+        <link rel="shortcut icon" type="image/x-icon" href="chrome://theme/current-channel-logo@2x">
+        <style>
+          @import url(chrome://resources/css/text_defaults_md.css);
+          body { text-align: center; align-content: center; min-height: 100vh; margin: auto; }
+          img { max-width: min(90vw, 512px); height: auto; }
+        </style>
+      </head>
+      <body>
+        <img alt="Thorium Robot" src="chrome://theme/IDR_PRODUCT_ROBOT">
+      </body>
+      </html>
+    )";
+  std::move(callback).Run(
+      base::MakeRefCounted<base::RefCountedString>(std::move(source)));
+}
