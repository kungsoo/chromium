+void ExtensionsMenuMainPageView::UpdateExtensionQuickToggles(
+    std::vector<ExtensionQuickToggleState> states) {
+  if (!base::FeatureList::IsEnabled(features::kExtensionsMenuQuickToggle)) {
+    quick_toggle_section_->SetVisible(false);
+    return;
+  }
+
+  quick_toggle_entries_->RemoveAllChildViews();
+  quick_toggle_section_->SetVisible(!states.empty());
+  menu_entries_->SetVisible(!menu_entries_->children().empty());
+  const ExtensionQuickToggleSummary summary =
+      GetExtensionQuickToggleSummary(states);
+  quick_toggle_all_toggle_->SetEnabled(summary.has_toggleable_extension);
+  quick_toggle_all_toggle_->SetIsOn(
+      summary.all_toggleable_extensions_enabled);
+
+  ChromeLayoutProvider* const chrome_layout_provider =
+      ChromeLayoutProvider::Get();
+  const int control_vertical_spacing =
+      chrome_layout_provider->GetDistanceMetric(
+          DISTANCE_RELATED_CONTROL_VERTICAL_SMALL);
+  const int horizontal_spacing =
+      chrome_layout_provider->GetDistanceMetric(
+          DISTANCE_RELATED_LABEL_HORIZONTAL_LIST);
+
+  for (const ExtensionQuickToggleState& state : states) {
+    views::ToggleButton* toggle = nullptr;
+    auto row =
+        views::Builder<views::FlexLayoutView>()
+            .SetOrientation(views::LayoutOrientation::kHorizontal)
+            .SetCrossAxisAlignment(views::LayoutAlignment::kCenter)
+            .SetProperty(views::kMarginsKey,
+                         gfx::Insets::TLBR(control_vertical_spacing, 0, 0, 0))
+            .AddChildren(
+                views::Builder<views::Label>()
+                    .SetText(state.display_name)
+                    .SetTextStyle(views::style::STYLE_BODY_3_EMPHASIS)
+                    .SetEnabledColor(kColorExtensionsMenuText)
+                    .SetHorizontalAlignment(gfx::ALIGN_LEFT)
+                    .SetElideBehavior(gfx::ELIDE_TAIL)
+                    .SetProperty(views::kFlexBehaviorKey,
+                                 views::FlexSpecification(
+                                     views::LayoutOrientation::kHorizontal,
+                                     views::MinimumFlexSizeRule::kScaleToZero,
+                                     views::MaximumFlexSizeRule::kUnbounded)),
+                views::Builder<views::ToggleButton>()
+                    .CopyAddressTo(&toggle)
+                    .SetProperty(views::kMarginsKey,
+                                 gfx::Insets::TLBR(0, horizontal_spacing, 0, 0))
+                    .SetAccessibleName(state.display_name)
+                    .SetCallback(base::BindRepeating(
+                        [](views::ToggleButton* toggle_button,
+                           base::RepeatingCallback<void(bool)> callback) {
+                          callback.Run(toggle_button->GetIsOn());
+                        },
+                        toggle,
+                        base::BindRepeating(
+                            &ExtensionsMenuHandler::
+                                OnExtensionEnableToggleSelected,
+                            base::Unretained(menu_handler_), state.id))))
+            .Build();
+
+    toggle->SetIsOn(state.enabled);
+    toggle->SetEnabled(state.can_toggle);
+    quick_toggle_entries_->AddChildView(std::move(row));
+  }
+
+  SizeToPreferredSize();
+}
