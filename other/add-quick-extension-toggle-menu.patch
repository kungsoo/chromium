+  section->AddChildView(std::move(entries));
+
+  UpdateExtensionQuickToggles();
+  return section;
+}
+
+void ExtensionsMenuView::UpdateExtensionQuickToggles() {
+  if (!quick_toggle_entries_) {
+    return;
+  }
+
+  if (!base::FeatureList::IsEnabled(features::kExtensionsMenuQuickToggle)) {
+    quick_toggle_section_->SetVisible(false);
+    return;
+  }
+
+  quick_toggle_entries_->RemoveAllChildViews();
+  std::vector<ExtensionQuickToggleState> states =
+      GetExtensionQuickToggleStates(browser_->GetProfile());
+  quick_toggle_section_->SetVisible(!states.empty());
+  const ExtensionQuickToggleSummary summary =
+      GetExtensionQuickToggleSummary(states);
+  quick_toggle_all_toggle_->SetEnabled(summary.has_toggleable_extension);
+  quick_toggle_all_toggle_->SetIsOn(
+      summary.all_toggleable_extensions_enabled);
+
+  ChromeLayoutProvider* const provider = ChromeLayoutProvider::Get();
+  const int row_spacing =
+      provider->GetDistanceMetric(DISTANCE_RELATED_CONTROL_VERTICAL_SMALL);
+  const int toggle_spacing =
+      provider->GetDistanceMetric(DISTANCE_RELATED_LABEL_HORIZONTAL_LIST);
+
+  for (const ExtensionQuickToggleState& state : states) {
+    views::ToggleButton* toggle = nullptr;
+    auto row = std::make_unique<views::View>();
+    auto layout = std::make_unique<views::BoxLayout>(
+        views::BoxLayout::Orientation::kHorizontal);
+    views::BoxLayout* layout_ptr = layout.get();
+    row->SetLayoutManager(std::move(layout));
+    row->SetBorder(
+        views::CreateEmptyBorder(gfx::Insets::TLBR(row_spacing, 0, 0, 0)));
+
+    auto label = std::make_unique<views::Label>(
+        state.display_name, views::style::CONTEXT_DIALOG_BODY_TEXT,
+        views::style::STYLE_PRIMARY);
+    label->SetHorizontalAlignment(gfx::ALIGN_LEFT);
+    label->SetElideBehavior(gfx::ELIDE_TAIL);
+    views::Label* label_ptr = row->AddChildView(std::move(label));
+
+    auto toggle_button = std::make_unique<views::ToggleButton>();
+    toggle = toggle_button.get();
+    toggle->SetCallback(base::BindRepeating(
+        [](views::ToggleButton* toggle_button,
+           base::RepeatingCallback<void(bool)> callback) {
+          callback.Run(toggle_button->GetIsOn());
+        },
+        toggle,
+        base::BindRepeating(
+            &ExtensionsMenuView::OnExtensionEnableToggleSelected,
+            base::Unretained(this), state.id)));
+    toggle->SetAccessibleName(state.display_name);
+    toggle->SetBorder(
+        views::CreateEmptyBorder(gfx::Insets::TLBR(0, toggle_spacing, 0, 0)));
+    row->AddChildView(std::move(toggle_button));
+
+    layout_ptr->SetFlexForView(label_ptr, 1);
+    toggle->SetIsOn(state.enabled);
+    toggle->SetEnabled(state.can_toggle);
+    quick_toggle_entries_->AddChildView(std::move(row));
+  }
+
+  RefreshLayoutAfterMenuItemsChanged();
+}
+
+void ExtensionsMenuView::OnExtensionEnableToggleSelected(
+    const extensions::ExtensionId& extension_id,
+    bool is_on) {
+  SetExtensionQuickToggleEnabled(browser_->GetProfile(), extension_id, is_on);
+}
+
+void ExtensionsMenuView::OnAllExtensionsEnableToggleSelected(bool is_on) {
+  {
+    base::AutoReset<bool> reset(&is_updating_all_extension_toggles_, true);
+    SetAllExtensionQuickTogglesEnabled(browser_->GetProfile(), is_on);
+  }
+  UpdateExtensionQuickToggles();
+}
+
+void ExtensionsMenuView::MaybeUpdateExtensionQuickToggles() {
+  if (is_updating_all_extension_toggles_) {
+    return;
+  }
+  UpdateExtensionQuickToggles();
+}
