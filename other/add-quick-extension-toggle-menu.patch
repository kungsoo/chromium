+      views::style::CONTEXT_DIALOG_BODY_TEXT, views::style::STYLE_PRIMARY);
+  all_extensions_label->SetHorizontalAlignment(gfx::ALIGN_RIGHT);
+  all_extensions_label->SetBorder(
+      views::CreateEmptyBorder(gfx::Insets::TLBR(0, 8, 0, 0)));
+  header_row->AddChildView(std::move(all_extensions_label));
+
+  auto all_extensions_toggle = std::make_unique<views::ToggleButton>();
+  quick_toggle_all_toggle_ = all_extensions_toggle.get();
+  all_extensions_toggle->SetAccessibleName(l10n_util::GetStringUTF16(
+      IDS_EXTENSIONS_MENU_QUICK_TOGGLE_ALL_EXTENSIONS));
+  all_extensions_toggle->SetBorder(
+      views::CreateEmptyBorder(gfx::Insets::TLBR(0, 8, 0, 0)));
+  all_extensions_toggle->SetCallback(base::BindRepeating(
+      [](views::ToggleButton* toggle_button,
+         base::RepeatingCallback<void(bool)> callback) {
+        callback.Run(toggle_button->GetIsOn());
+      },
+      quick_toggle_all_toggle_,
+      base::BindRepeating(
+          &ExtensionsMenuView::OnAllExtensionsEnableToggleSelected,
+          base::Unretained(this))));
+  header_row->AddChildView(std::move(all_extensions_toggle));
+
+  header_layout_ptr->SetFlexForView(header_ptr, 1);
+  section->AddChildView(std::move(header_row));
+
