+ExtensionQuickToggleState::ExtensionQuickToggleState(
+    extensions::ExtensionId id,
+    std::string name,
+    bool enabled,
+    bool can_toggle)
+    : id(std::move(id)),
+      display_name(base::UTF8ToUTF16(name)),
+      sort_key(base::i18n::ToLower(display_name)),
+      enabled(enabled),
+      can_toggle(can_toggle) {}
+
+ExtensionQuickToggleState::ExtensionQuickToggleState(
+    const ExtensionQuickToggleState&) = default;
+ExtensionQuickToggleState& ExtensionQuickToggleState::operator=(
+    const ExtensionQuickToggleState&) = default;
+ExtensionQuickToggleState::~ExtensionQuickToggleState() = default;
+
+bool ExtensionQuickToggleState::operator<(
+    const ExtensionQuickToggleState& other) const {
+  return sort_key < other.sort_key;
+}
+
+ExtensionQuickToggleSummary GetExtensionQuickToggleSummary(
+    const std::vector<ExtensionQuickToggleState>& states) {
+  bool has_toggleable_extension = false;
+  bool all_toggleable_extensions_enabled = true;
+  for (const ExtensionQuickToggleState& state : states) {
+    if (!state.can_toggle) {
+      continue;
+    }
+    has_toggleable_extension = true;
+    all_toggleable_extensions_enabled &= state.enabled;
+  }
+  return {has_toggleable_extension,
+          has_toggleable_extension && all_toggleable_extensions_enabled};
+}
+
+void SetExtensionQuickToggleEnabled(Profile* profile,
+                                    const extensions::ExtensionId& extension_id,
+                                    bool is_enabled) {
+  auto* registrar = extensions::ExtensionRegistrar::Get(profile);
+  if (is_enabled) {
+    registrar->EnableExtension(extension_id);
+  } else {
+    registrar->DisableExtension(
+        extension_id, {extensions::disable_reason::DISABLE_USER_ACTION});
+  }
+}
+
+void SetAllExtensionQuickTogglesEnabled(Profile* profile, bool is_enabled) {
+  for (const ExtensionQuickToggleState& state :
+       GetExtensionQuickToggleStates(profile)) {
+    if (!state.can_toggle || state.enabled == is_enabled) {
+      continue;
+    }
+    SetExtensionQuickToggleEnabled(profile, state.id, is_enabled);
+  }
+}
+
+std::vector<ExtensionQuickToggleState> GetExtensionQuickToggleStates(
+    Profile* profile) {
+  std::vector<ExtensionQuickToggleState> states;
+  auto* registry = extensions::ExtensionRegistry::Get(profile);
+  auto* extension_system = extensions::ExtensionSystem::Get(profile);
+  auto* extension_service = extension_system->extension_service();
+  auto* management_policy = extension_system->management_policy();
+
+  for (const auto& extension : registry->GenerateInstalledExtensionsSet(
+           extensions::ExtensionRegistry::ENABLED |
+           extensions::ExtensionRegistry::DISABLED |
+           extensions::ExtensionRegistry::TERMINATED)) {
+    if (!extension->is_extension()) {
+      continue;
+    }
+
+    const bool is_enabled =
+        registry->enabled_extensions().Contains(extension->id()) ||
+        registry->terminated_extensions().Contains(extension->id());
+    const bool can_toggle =
+        is_enabled ? extension_service->UserCanDisableInstalledExtension(
+                         extension->id())
+                   : !management_policy->MustRemainDisabled(extension.get(),
+                                                            nullptr);
+    states.emplace_back(extension->id(), extension->name(), is_enabled,
+                        can_toggle);
+  }
+
+  std::sort(states.begin(), states.end());
+  return states;
+}
