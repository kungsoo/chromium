 int TabStyle::GetStandardWidth(const bool is_split) const {
+  const std::string custom_tab_width =
+      base::CommandLine::ForCurrentProcess()->GetSwitchValueASCII(
+          "custom-tab-width");
+  int tab_width = kTabWidth;
+  if (custom_tab_width == "60") {
+    tab_width = 60;
+  } else if (custom_tab_width == "120") {
+    tab_width = 120;
+  } else if (custom_tab_width == "180") {
+    tab_width = 180;
+  } else if (custom_tab_width == "240") {
+    tab_width = 240;
+  } else if (custom_tab_width == "300") {
+    tab_width = 300;
+  } else if (custom_tab_width == "400") {
+    tab_width = 400;
+  }
+
   if (is_split) {
     // Split tabs appear as half width with one bottom extension. They also must
     // include half the tab overlap as the tabs fill the space between them.
-    return kTabWidth / 2 + GetBottomCornerRadius() + GetTabOverlap() / 2;
+    return tab_width / 2 + GetBottomCornerRadius() + GetTabOverlap() / 2;
   } else {
     // The full width includes two extensions with the bottom corner radius.
-    return kTabWidth + 2 * GetBottomCornerRadius();
+    return tab_width + 2 * GetBottomCornerRadius();
   }
 }
 
