diff --git a/cdm/BUILD.gn b/cdm/BUILD.gn
index 6d18f9fa16371..8ec51a6aed383 100644
--- a/cdm/BUILD.gn
+++ b/cdm/BUILD.gn
@@ -26,6 +26,12 @@ buildflag_header("buildflags") {
 }
 
 if (bundle_widevine_cdm) {
+  if (target_os == "linux" && target_cpu == "arm64") {
+    assert(widevine_root != ".",
+           "Bundled Linux ARM64 Widevine requires an explicit widevine_root " +
+               "containing a linux/arm64 payload.")
+  }
+
   widevine_arch = target_cpu
 
   widevine_cdm_root = "${widevine_root}/${target_os}/${widevine_arch}"
@@ -37,6 +43,11 @@ if (bundle_widevine_cdm) {
   ]
 
   if (enable_widevine_cdm_host_verification) {
+    assert(bundle_widevine_cdm_signature,
+           "CDM host verification requires the bundled CDM signature.")
+  }
+
+  if (bundle_widevine_cdm_signature) {
     assert(is_win || is_mac)
     widevine_cdm_binary_files += [ "${widevine_cdm_root}/${cdm_file_name}.sig" ]
   }
