diff --git a/build/config/compiler_opt.gni b/build/config/compiler_opt.gni
new file mode 100644
index 0000000000000..59cc302488e85
--- /dev/null
+++ b/build/config/compiler_opt.gni
@@ -0,0 +1,227 @@
+# Copyright 2026 Alex313031
+# Use of this source code is governed by a BSD-style license that can be
+# found in the LICENSE file.
+
+import("//build/config/compiler/compiler.gni")
+
+declare_args() {
+  # Use maximum optimization for official Thorium builds.
+  is_full_optimization_build = is_official_build
+
+  # Whether to use Raspberry Pi specific optimizations.
+  is_raspi = false
+}
+
+_thorium_x86_profile_platform =
+    is_win || is_linux || is_mac || is_android || is_chromeos || is_fuchsia
+
+_default_thorium_x86_profile = "none"
+if (_thorium_x86_profile_platform &&
+    (target_cpu == "x86" || target_cpu == "x64")) {
+  _default_thorium_x86_profile = "sse3"
+}
+
+declare_args() {
+  # Selects the minimum x86 CPU feature set for Thorium targets. This is the
+  # only public SIMD compatibility setting; tuning and package names are
+  # derived from it.
+  thorium_x86_profile = _default_thorium_x86_profile
+}
+
+_thorium_x86_profile_is_valid =
+    thorium_x86_profile == "none" || thorium_x86_profile == "sse2" ||
+    thorium_x86_profile == "sse3" || thorium_x86_profile == "sse4_1" ||
+    thorium_x86_profile == "sse4_2" || thorium_x86_profile == "avx" ||
+    thorium_x86_profile == "avx_fma" || thorium_x86_profile == "avx2" ||
+    thorium_x86_profile == "avx2_fma" || thorium_x86_profile == "avx512_skx"
+assert(_thorium_x86_profile_is_valid,
+       "Unsupported thorium_x86_profile: " + thorium_x86_profile)
+assert(thorium_x86_profile == "none" || _thorium_x86_profile_platform,
+       "thorium_x86_profile is not supported for this target platform")
+assert(
+    thorium_x86_profile == "none" || target_cpu == "x86" || target_cpu == "x64",
+    "thorium_x86_profile requires an x86 or x64 target")
+
+if (is_debug) {
+  assert(!is_full_optimization_build,
+         "is_full_optimization_build only works with non-debug builds")
+}
+
+thorium_x86_isa_cflags = []
+thorium_x86_isa_rustflags = []
+thorium_x86_tune_cflags = []
+thorium_x86_tune_rustflags = []
+thorium_x86_numeric_cflags = []
+thorium_x86_numeric_rustflags = []
+
+# Required CPU capabilities encoded for lightweight runtime guards. Bit layout
+# is documented at the consumers; zero means no Thorium x86 ISA requirement.
+thorium_x86_required_cpu_features = 0
+thorium_windows_installer_label = ""
+thorium_linux_package_suffix = ""
+
+_thorium_x86_apply_profile =
+    is_a_target_toolchain && _thorium_x86_profile_platform &&
+    (current_cpu == "x86" || current_cpu == "x64")
+
+# ChromeOS device toolchains with an explicit -march own their complete ISA.
+if (defined(cros_target_cpu_arch) && cros_target_cpu_arch != "") {
+  _thorium_x86_apply_profile = false
+}
+
+if (_thorium_x86_apply_profile) {
+  if (thorium_x86_profile == "sse2") {
+    thorium_x86_required_cpu_features = 1
+    thorium_x86_isa_cflags = [ "-msse2" ]
+    thorium_x86_isa_rustflags = [ "-Ctarget-feature=+sse2" ]
+  } else if (thorium_x86_profile == "sse3") {
+    thorium_x86_required_cpu_features = 2
+    thorium_x86_isa_cflags = [ "-msse3" ]
+    thorium_x86_isa_rustflags = [ "-Ctarget-feature=+sse3" ]
+  } else if (thorium_x86_profile == "sse4_1") {
+    thorium_x86_required_cpu_features = 14
+    thorium_x86_isa_cflags = [
+      "-msse3",
+      "-mssse3",
+      "-msse4.1",
+    ]
+    thorium_x86_isa_rustflags = [ "-Ctarget-feature=+sse3,+ssse3,+sse4.1" ]
+    thorium_x86_tune_cflags = [ "-mtune=core2" ]
+    thorium_x86_tune_rustflags = [ "-Ztune-cpu=core2" ]
+  } else if (thorium_x86_profile == "sse4_2") {
+    thorium_x86_required_cpu_features = 30
+    thorium_x86_isa_cflags = [
+      "-msse3",
+      "-mssse3",
+      "-msse4.1",
+      "-msse4.2",
+    ]
+    thorium_x86_isa_rustflags =
+        [ "-Ctarget-feature=+sse3,+ssse3,+sse4.1,+sse4.2" ]
+    thorium_x86_tune_cflags = [ "-mtune=nehalem" ]
+    thorium_x86_tune_rustflags = [ "-Ztune-cpu=nehalem" ]
+  } else if (thorium_x86_profile == "avx") {
+    thorium_x86_required_cpu_features = 34
+    thorium_x86_isa_cflags = [
+      "-msse3",
+      "-mavx",
+    ]
+    thorium_x86_isa_rustflags = [ "-Ctarget-feature=+sse3,+avx,-fast-gather,+prefer-no-gather,+prefer-no-scatter" ]
+    thorium_x86_tune_cflags = [
+      "-mtune=sandybridge",
+      "-mno-gather",
+      "-mno-scatter",
+    ]
+    thorium_x86_tune_rustflags = [ "-Ztune-cpu=sandybridge" ]
+  } else if (thorium_x86_profile == "avx_fma") {
+    thorium_x86_required_cpu_features = 98
+    thorium_x86_isa_cflags = [
+      "-msse3",
+      "-mavx",
+      "-mfma",
+    ]
+    thorium_x86_isa_rustflags = [ "-Ctarget-feature=+sse3,+avx,+fma,-fast-gather,+prefer-no-gather,+prefer-no-scatter" ]
+    thorium_x86_tune_cflags = [
+      "-mtune=piledriver",
+      "-mno-gather",
+      "-mno-scatter",
+    ]
+    thorium_x86_tune_rustflags = [ "-Ztune-cpu=bdver2" ]
+  } else if (thorium_x86_profile == "avx2" ||
+             thorium_x86_profile == "avx2_fma" ||
+             thorium_x86_profile == "avx512_skx") {
+    thorium_x86_required_cpu_features = 162
+    thorium_x86_isa_cflags = [
+      "-msse3",
+      "-mavx",
+      "-mavx2",
+    ]
+    _thorium_rust_target_features = "+sse3,+avx,+avx2"
+
+    if (thorium_x86_profile == "avx2_fma" ||
+        thorium_x86_profile == "avx512_skx") {
+      thorium_x86_required_cpu_features = 482
+      thorium_x86_isa_cflags += [
+        "-mfma",
+        "-mf16c",
+      ]
+      _thorium_rust_target_features += ",+fma,+f16c"
+    }
+
+    if (thorium_x86_profile == "avx512_skx") {
+      thorium_x86_required_cpu_features = 16354
+      thorium_x86_isa_cflags += [
+        "-mavx512f",
+        "-mavx512cd",
+        "-mavx512vl",
+        "-mavx512bw",
+        "-mavx512dq",
+      ]
+      _thorium_rust_target_features +=
+          ",+avx512f,+avx512cd,+avx512vl,+avx512bw,+avx512dq"
+      thorium_x86_tune_cflags = [ "-mtune=skylake-avx512" ]
+      thorium_x86_tune_rustflags = [ "-Ztune-cpu=skylake-avx512" ]
+    } else {
+      thorium_x86_tune_cflags = [ "-mtune=skylake" ]
+      thorium_x86_tune_rustflags = [ "-Ztune-cpu=skylake" ]
+    }
+
+    _thorium_rust_target_features +=
+        ",-fast-gather,+prefer-no-gather,+prefer-no-scatter"
+    thorium_x86_isa_rustflags =
+        [ "-Ctarget-feature=" + _thorium_rust_target_features ]
+    thorium_x86_tune_cflags += [
+      "-mno-gather",
+      "-mno-scatter",
+    ]
+  }
+
+  _thorium_fp_contract = "off"
+  if (thorium_x86_profile == "avx2_fma" ||
+      thorium_x86_profile == "avx512_skx") {
+    _thorium_fp_contract = "fast"
+  }
+  if (is_win) {
+    thorium_x86_numeric_cflags =
+        [ "/clang:-ffp-contract=" + _thorium_fp_contract ]
+  } else {
+    thorium_x86_numeric_cflags = [ "-ffp-contract=" + _thorium_fp_contract ]
+  }
+  thorium_x86_numeric_rustflags =
+      [ "-Cllvm-args=-fp-contract=" + _thorium_fp_contract ]
+}
+
+if (_thorium_x86_apply_profile) {
+  if (thorium_x86_profile == "sse2") {
+    thorium_windows_installer_label = "WIN32_SSE2"
+    thorium_linux_package_suffix = "_SSE2"
+  } else if (thorium_x86_profile == "sse3") {
+    if (current_cpu == "x86") {
+      thorium_windows_installer_label = "WIN32_SSE3"
+    } else {
+      thorium_windows_installer_label = "SSE3"
+    }
+    thorium_linux_package_suffix = "_SSE3"
+  } else if (thorium_x86_profile == "sse4_1") {
+    thorium_windows_installer_label = "SSE4"
+    thorium_linux_package_suffix = "_SSE4"
+  } else if (thorium_x86_profile == "sse4_2") {
+    thorium_windows_installer_label = "SSE4.2"
+    thorium_linux_package_suffix = "_SSE4.2"
+  } else if (thorium_x86_profile == "avx") {
+    thorium_windows_installer_label = "AVX"
+    thorium_linux_package_suffix = "_AVX"
+  } else if (thorium_x86_profile == "avx_fma") {
+    thorium_windows_installer_label = "AVX-FMA"
+    thorium_linux_package_suffix = "_AVX-FMA"
+  } else if (thorium_x86_profile == "avx2") {
+    thorium_windows_installer_label = "AVX2-min"
+    thorium_linux_package_suffix = "_AVX2-min"
+  } else if (thorium_x86_profile == "avx2_fma") {
+    thorium_windows_installer_label = "AVX2"
+    thorium_linux_package_suffix = "_AVX2"
+  } else if (thorium_x86_profile == "avx512_skx") {
+    thorium_windows_installer_label = "AVX512"
+    thorium_linux_package_suffix = "_AVX512"
+  }
+}
