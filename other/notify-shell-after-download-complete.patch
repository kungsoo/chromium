   download_file->Cancel();
 }
 
+#if BUILDFLAG(IS_WIN)
+void NotifyShellOfCompletedDownload(const base::FilePath& full_path,
+                                    bool path_changed) {
+  SHChangeNotify(path_changed ? SHCNE_CREATE : SHCNE_UPDATEITEM,
+                 SHCNF_PATH | SHCNF_FLUSHNOWAIT,
+                 full_path.value().c_str(), nullptr);
+
+  base::FilePath parent_dir = full_path.DirName();
+  if (!parent_dir.empty()) {
+    SHChangeNotify(SHCNE_UPDATEDIR, SHCNF_PATH | SHCNF_FLUSHNOWAIT,
+                   parent_dir.value().c_str(), nullptr);
+  }
+}
+#endif  // BUILDFLAG(IS_WIN)
