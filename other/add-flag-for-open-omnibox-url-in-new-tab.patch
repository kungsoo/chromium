+WindowOpenDisposition MaybeOverrideOmniboxCurrentTabDisposition(
+    WindowOpenDisposition disposition) {
+  if (disposition != WindowOpenDisposition::CURRENT_TAB ||
+      !base::FeatureList::IsEnabled(features::kOpenOmniboxUrlInNewTab)) {
+    return disposition;
+  }
+
+  const std::string mode = features::kOpenOmniboxUrlInNewTabMode.Get();
+  if (mode == "background") {
+    return WindowOpenDisposition::NEW_BACKGROUND_TAB;
+  }
+
+  // Default to foreground for unknown values as well as the default parameter.
+  return WindowOpenDisposition::NEW_FOREGROUND_TAB;
+}
