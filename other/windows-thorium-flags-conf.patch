+
+std::string NormalizeThoriumFlagsFileContents(std::string contents) {
+  static constexpr char kUtf8ByteOrderMark[] = "\xEF\xBB\xBF";
+  if (base::StartsWith(contents, kUtf8ByteOrderMark)) {
+    contents.erase(0, 3);
+  }
+
+  std::string command_line;
+  for (std::string_view line :
+       base::SplitStringPiece(contents, "\n", base::KEEP_WHITESPACE,
+                              base::SPLIT_WANT_ALL)) {
+    line = base::TrimWhitespaceASCII(line, base::TRIM_ALL);
+    if (line.empty() || line.front() == '#') {
+      continue;
+    }
+    if (!command_line.empty()) {
+      command_line.push_back(' ');
+    }
+    command_line.append(line);
+  }
+  return command_line;
+}
+
+void AppendThoriumFlagsFromFile(
+    const base::FilePath& flags_file,
+    const std::set<std::string>& explicit_switches,
+    base::CommandLine* command_line) {
+  std::string contents;
+  if (!base::ReadFileToString(flags_file, &contents)) {
+    return;
+  }
+
+  const std::string flags = NormalizeThoriumFlagsFileContents(contents);
+  if (flags.empty()) {
+    return;
+  }
+
+  base::CommandLine flags_command_line(base::CommandLine::NO_PROGRAM);
+  flags_command_line.ParseFromString(
+      L"thorium-flags.conf " + base::UTF8ToWide(flags));
+
+  for (const auto& [switch_name, switch_value] :
+       flags_command_line.GetSwitches()) {
+    if (switch_name == switches::kProcessType ||
+        switch_name == switches::kUserDataDir ||
+        explicit_switches.contains(switch_name)) {
+      continue;
+    }
+    command_line->AppendSwitchNative(switch_name, switch_value);
+  }
+}
+
+void AppendThoriumFlagsFromConfigFiles(base::CommandLine* command_line) {
+  std::set<std::string> explicit_switches;
+  for (const auto& [switch_name, switch_value] : command_line->GetSwitches()) {
+    explicit_switches.insert(switch_name);
+  }
+
+  base::FilePath exe_dir;
+  if (base::PathService::Get(base::DIR_EXE, &exe_dir)) {
+    AppendThoriumFlagsFromFile(exe_dir.Append(kThoriumFlagsFileName),
+                               explicit_switches, command_line);
+  }
+
+  base::FilePath roaming_app_data_dir;
+  if (base::PathService::Get(base::DIR_ROAMING_APP_DATA,
+                             &roaming_app_data_dir)) {
+    AppendThoriumFlagsFromFile(
+        roaming_app_data_dir.Append(kThoriumFlagsConfigDirName)
+            .Append(kThoriumFlagsFileName),
+        explicit_switches, command_line);
+  }
+}
+#endif  // BUILDFLAG(IS_WIN)
