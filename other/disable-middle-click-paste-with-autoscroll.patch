 namespace {
 
+#if BUILDFLAG(IS_LINUX)
+constexpr char kMiddleClickAutoscrollBlinkFeature[] =
+    "MiddleClickAutoscroll";
+constexpr char kDisableBlinkFeaturesSwitch[] = "disable-blink-features";
+constexpr char kEnableBlinkFeaturesSwitch[] = "enable-blink-features";
+constexpr char kEnableBlinkTestFeaturesSwitch[] = "enable-blink-test-features";
+
+bool BlinkFeatureSwitchContains(const base::CommandLine& command_line,
+                                const char* switch_name,
+                                const char* feature_name) {
+  return std::ranges::contains(
+      base::SplitString(command_line.GetSwitchValueASCII(switch_name), ",",
+                        base::TRIM_WHITESPACE, base::SPLIT_WANT_NONEMPTY),
+      feature_name);
+}
+
+bool IsMiddleClickAutoscrollEnabledFromCommandLine() {
+  const base::CommandLine& command_line =
+      *base::CommandLine::ForCurrentProcess();
+  if (BlinkFeatureSwitchContains(command_line, kDisableBlinkFeaturesSwitch,
+                                 kMiddleClickAutoscrollBlinkFeature)) {
+    return false;
+  }
+  return command_line.HasSwitch(kEnableBlinkTestFeaturesSwitch) ||
+         BlinkFeatureSwitchContains(command_line, kEnableBlinkFeaturesSwitch,
+                                    kMiddleClickAutoscrollBlinkFeature);
+}
+#endif
