diff --git a/chrome/browser/ui/bookmarks/bookmark_utils_desktop.cc b/chrome/browser/ui/bookmarks/bookmark_utils_desktop.cc
index bf25013da7b21..1998487f7731e 100644
--- a/chrome/browser/ui/bookmarks/bookmark_utils_desktop.cc
+++ b/chrome/browser/ui/bookmarks/bookmark_utils_desktop.cc
@@ -8,6 +8,7 @@
 #include <numeric>
 
 #include "base/containers/flat_set.h"
+#include "base/feature_list.h"
 #include "base/functional/bind.h"
 #include "base/functional/callback.h"
 #include "base/memory/raw_ptr.h"
@@ -582,6 +583,20 @@ void OpenAllIfAllowed(
     page_load_metrics::NavigationHandleUserData::InitiatorLocation
         navigation_type,
     std::optional<BookmarkLaunchAction> launch_action) {
+  // Convert single-bookmark left clicks from current-tab navigation to a new
+  // foreground/background tab when the feature is enabled. Folder opens and
+  // explicit dispositions such as middle-click are left unchanged.
+  if (base::FeatureList::IsEnabled(features::kOpenBookmarksInNewTab) &&
+      initial_disposition == WindowOpenDisposition::CURRENT_TAB &&
+      nodes.size() == 1 && nodes[0]->is_url()) {
+    const std::string mode = features::kOpenBookmarksInNewTabMode.Get();
+    if (mode == "background") {
+      initial_disposition = WindowOpenDisposition::NEW_BACKGROUND_TAB;
+    } else {
+      initial_disposition = WindowOpenDisposition::NEW_FOREGROUND_TAB;
+    }
+  }
+
   std::vector<UrlAndId> url_and_ids = GetURLsToOpen(
       nodes, initial_disposition == WindowOpenDisposition::OFF_THE_RECORD);
 
