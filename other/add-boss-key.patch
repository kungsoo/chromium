+void SystemHandler::HandleGetBossKeySettings(const base::ListValue& args) {
+  AllowJavascript();
+  ResolveJavascriptCallback(args[0], GetBossKeySettings());
+}
+
+void SystemHandler::HandleSetBossKeyEnabled(const base::ListValue& args) {
+  AllowJavascript();
+  g_browser_process->GetFeatures()->boss_key_service()->SetEnabled(
+      args[1].GetBool());
+  ResolveJavascriptCallback(args[0], GetBossKeySettings());
+}
+
+void SystemHandler::HandleSetBossKeyMuteBrowsers(
+    const base::ListValue& args) {
+  AllowJavascript();
+  g_browser_process->GetFeatures()->boss_key_service()->SetMuteBrowsers(
+      args[1].GetBool());
+  ResolveJavascriptCallback(args[0], GetBossKeySettings());
+}
+
+void SystemHandler::HandleSetBossKeyShortcut(const base::ListValue& args) {
+  AllowJavascript();
+  const bool valid =
+      g_browser_process->GetFeatures()->boss_key_service()->SetShortcut(
+          args[1].GetString(), args[2].GetInt());
+  ResolveJavascriptCallback(args[0], GetBossKeySettings(valid));
+}
+
+void SystemHandler::HandleSetBossKeyCaptureActive(
+    const base::ListValue& args) {
+  g_browser_process->GetFeatures()
+      ->boss_key_service()
+      ->SetShortcutCaptureActive(args[0].GetBool());
+}
+
+void SystemHandler::OnJavascriptDisallowed() {
+  g_browser_process->GetFeatures()
+      ->boss_key_service()
+      ->SetShortcutCaptureActive(false);
+}
+
 }  // namespace settings
