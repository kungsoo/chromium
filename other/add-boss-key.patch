+
+class PrefRegistrySimple;
+
+namespace tabs {
+class TabInterface;
+}
+
+namespace boss_key {
+
+// Owns the installation-wide boss key shortcut and the transient window/audio
+// state needed to restore the browser exactly as it was before it was hidden.
+class BossKeyService : public ui::GlobalAcceleratorListener::Observer {
+ public:
+  BossKeyService();
+  BossKeyService(const BossKeyService&) = delete;
+  BossKeyService& operator=(const BossKeyService&) = delete;
+  ~BossKeyService() override;
+
+  static void RegisterLocalStatePrefs(PrefRegistrySimple* registry);
+
+  bool enabled() const;
+  bool mute_browsers() const;
+  bool registered() const { return registered_; }
+  std::string shortcut_text() const;
+
+  void SetEnabled(bool enabled);
+  void SetMuteBrowsers(bool mute_browsers);
+  bool SetShortcut(const std::string& code, int modifiers);
+  void SetShortcutCaptureActive(bool active);
+
+  // ui::GlobalAcceleratorListener::Observer:
+  void OnKeyPressed(const ui::Accelerator& accelerator) override;
+  void ExecuteCommand(const std::string& accelerator_group_id,
+                      const std::string& command_id) override;
+
+ private:
+  std::string shortcut_code() const;
+  int shortcut_modifiers() const;
+
+  struct MutedTabState {
+    MutedTabState(base::WeakPtr<tabs::TabInterface> tab, bool was_muted);
+    MutedTabState(MutedTabState&&);
+    MutedTabState& operator=(MutedTabState&&);
+    ~MutedTabState();
+
+    base::WeakPtr<tabs::TabInterface> tab;
+    bool was_muted;
+  };
+
+  std::optional<ui::Accelerator> AcceleratorFromSettings(
+      const std::string& code,
+      int modifiers) const;
+  void OnHotkeyPrefsChanged();
+  void OnMuteBrowsersPrefChanged();
+  void UpdateHotkeyRegistration();
+  void UnregisterHotkey();
+
+  void ToggleBrowsers();
+  void HideBrowsers();
+  void RestoreBrowsers();
+  void MuteBrowserTabs();
+  void RestoreBrowserTabs();
+
+  PrefChangeRegistrar pref_registrar_;
+  ui::Accelerator registered_accelerator_;
+  bool registered_ = false;
+  bool external_registration_active_ = false;
+  bool shortcut_capture_active_ = false;
+  bool updating_prefs_ = false;
+  bool windows_hidden_ = false;
+
+  std::vector<SessionID> hidden_window_ids_;
+  std::optional<SessionID> active_window_id_;
+  std::vector<MutedTabState> muted_tabs_;
+
+  base::WeakPtrFactory<BossKeyService> weak_ptr_factory_{this};
+};
+
+}  // namespace boss_key
+
+#endif  // CHROME_BROWSER_BOSS_KEY_BOSS_KEY_SERVICE_H_
