+++ b/chrome/browser/boss_key/boss_key_service.cc
@@ -0,0 +1,378 @@
+// Copyright 2026 The Thorium Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "chrome/browser/boss_key/boss_key_service.h"
+
+#include <utility>
+
+#include "base/functional/bind.h"
+#include "build/build_config.h"
+#include "chrome/browser/browser_process.h"
+#include "chrome/browser/ui/browser_window/public/browser_window_interface.h"
+#include "chrome/browser/ui/browser_window/public/global_browser_collection.h"
+#include "chrome/grit/generated_resources.h"
+#include "components/prefs/pref_registry_simple.h"
+#include "components/prefs/pref_service.h"
+#include "components/tabs/public/tab_interface.h"
+#include "content/public/browser/web_contents.h"
+#include "ui/base/accelerators/command.h"
+#include "ui/base/l10n/l10n_util.h"
+#include "ui/base/base_window.h"
+#include "ui/events/event_constants.h"
+#include "ui/events/keycodes/dom/keycode_converter.h"
+#include "ui/events/keycodes/keyboard_code_conversion.h"
+#include "ui/gfx/native_ui_types.h"
+
+namespace boss_key {
+
+namespace {
+
+constexpr char kEnabledPref[] = "boss_key.enabled";
+constexpr char kMuteBrowsersPref[] = "boss_key.mute_browsers";
+constexpr char kShortcutCodePref[] = "boss_key.shortcut_code";
+constexpr char kShortcutModifiersPref[] = "boss_key.shortcut_modifiers";
+
+constexpr char kAcceleratorGroupId[] = "thorium-boss-key";
+constexpr char kAcceleratorProfileId[] = "local-state";
+constexpr char kCommandId[] = "toggle-boss-key";
+
+constexpr int kAllowedModifiers = ui::EF_CONTROL_DOWN | ui::EF_ALT_DOWN |
+                                  ui::EF_SHIFT_DOWN | ui::EF_COMMAND_DOWN;
+
+std::string ShortcutText(const std::string& code, int modifiers) {
+  std::string text;
+  if (modifiers & ui::EF_CONTROL_DOWN) {
+    text += "Ctrl+";
+  }
+  if (modifiers & ui::EF_ALT_DOWN) {
+    text += "Alt+";
+  }
+  if (modifiers & ui::EF_SHIFT_DOWN) {
+    text += "Shift+";
+  }
+  if (modifiers & ui::EF_COMMAND_DOWN) {
+    text += "Command+";
+  }
+
+  if (code.starts_with("Key") && code.size() == 4) {
+    text += code.substr(3);
+  } else if (code.starts_with("Digit") && code.size() == 6) {
+    text += code.substr(5);
+  } else {
+    text += code;
+  }
+  return text;
+}
+
+}  // namespace
+
+BossKeyService::MutedTabState::MutedTabState(
+    base::WeakPtr<tabs::TabInterface> tab,
+    bool was_muted)
+    : tab(std::move(tab)), was_muted(was_muted) {}
+BossKeyService::MutedTabState::MutedTabState(MutedTabState&&) = default;
+BossKeyService::MutedTabState& BossKeyService::MutedTabState::operator=(
+    MutedTabState&&) = default;
+BossKeyService::MutedTabState::~MutedTabState() = default;
+
+BossKeyService::BossKeyService() {
+  pref_registrar_.Init(g_browser_process->local_state());
+  pref_registrar_.Add(
+      kEnabledPref,
+      base::BindRepeating(&BossKeyService::OnHotkeyPrefsChanged,
+                          base::Unretained(this)));
+  pref_registrar_.Add(
+      kMuteBrowsersPref,
+      base::BindRepeating(&BossKeyService::OnMuteBrowsersPrefChanged,
+                          base::Unretained(this)));
+  pref_registrar_.Add(
+      kShortcutCodePref,
+      base::BindRepeating(&BossKeyService::OnHotkeyPrefsChanged,
+                          base::Unretained(this)));
+  pref_registrar_.Add(
+      kShortcutModifiersPref,
+      base::BindRepeating(&BossKeyService::OnHotkeyPrefsChanged,
+                          base::Unretained(this)));
+  UpdateHotkeyRegistration();
+}
+
+BossKeyService::~BossKeyService() {
+  UnregisterHotkey();
+}
+
+// static
+void BossKeyService::RegisterLocalStatePrefs(PrefRegistrySimple* registry) {
+  registry->RegisterBooleanPref(kEnabledPref, false);
+  registry->RegisterBooleanPref(kMuteBrowsersPref, true);
+  registry->RegisterStringPref(kShortcutCodePref, "CapsLock");
+  registry->RegisterIntegerPref(kShortcutModifiersPref,
+                                ui::EF_CONTROL_DOWN);
+}
+
+bool BossKeyService::enabled() const {
+  return g_browser_process->local_state()->GetBoolean(kEnabledPref);
+}
+
+bool BossKeyService::mute_browsers() const {
+  return g_browser_process->local_state()->GetBoolean(kMuteBrowsersPref);
+}
+
+std::string BossKeyService::shortcut_code() const {
+  return g_browser_process->local_state()->GetString(kShortcutCodePref);
+}
+
+int BossKeyService::shortcut_modifiers() const {
+  return g_browser_process->local_state()->GetInteger(
+      kShortcutModifiersPref);
+}
+
+std::string BossKeyService::shortcut_text() const {
+  return ShortcutText(shortcut_code(), shortcut_modifiers());
+}
+
+void BossKeyService::SetEnabled(bool enabled) {
+  g_browser_process->local_state()->SetBoolean(kEnabledPref, enabled);
+}
+
+void BossKeyService::SetMuteBrowsers(bool mute_browsers) {
+  g_browser_process->local_state()->SetBoolean(kMuteBrowsersPref,
+                                                mute_browsers);
+}
+
+bool BossKeyService::SetShortcut(const std::string& code, int modifiers) {
+  if (!AcceleratorFromSettings(code, modifiers).has_value()) {
+    return false;
+  }
+
+  updating_prefs_ = true;
+  PrefService* local_state = g_browser_process->local_state();
+  local_state->SetString(kShortcutCodePref, code);
+  local_state->SetInteger(kShortcutModifiersPref, modifiers);
+  updating_prefs_ = false;
+  UpdateHotkeyRegistration();
+  return true;
+}
+
+void BossKeyService::SetShortcutCaptureActive(bool active) {
+  shortcut_capture_active_ = active;
+}
+
+std::optional<ui::Accelerator> BossKeyService::AcceleratorFromSettings(
+    const std::string& code,
+    int modifiers) const {
+  if ((modifiers & ~kAllowedModifiers) != 0 ||
+      (modifiers & kAllowedModifiers) == 0) {
+    return std::nullopt;
+  }
+#if !BUILDFLAG(IS_MAC)
+  if (modifiers & ui::EF_COMMAND_DOWN) {
+    return std::nullopt;
+  }
+#endif
+
+  const ui::DomCode dom_code = ui::KeycodeConverter::CodeStringToDomCode(code);
+  const ui::KeyboardCode key_code =
+      ui::DomCodeToUsLayoutNonLocatedKeyboardCode(dom_code);
+  if (dom_code == ui::DomCode::NONE || key_code == ui::VKEY_UNKNOWN) {
+    return std::nullopt;
+  }
+
+  return ui::Accelerator(key_code, modifiers);
+}
+
+void BossKeyService::OnHotkeyPrefsChanged() {
+  if (updating_prefs_) {
+    return;
+  }
+
+  if (!enabled() && windows_hidden_) {
+    RestoreBrowsers();
+  }
+  UpdateHotkeyRegistration();
+}
+
+void BossKeyService::OnMuteBrowsersPrefChanged() {
+  if (!windows_hidden_) {
+    return;
+  }
+
+  if (mute_browsers() && muted_tabs_.empty()) {
+    MuteBrowserTabs();
+  } else if (!mute_browsers() && !muted_tabs_.empty()) {
+    RestoreBrowserTabs();
+  }
+}
+
+void BossKeyService::UpdateHotkeyRegistration() {
+  ui::GlobalAcceleratorListener* listener =
+      ui::GlobalAcceleratorListener::GetInstance();
+  if (!listener) {
+    registered_ = false;
+    return;
+  }
+
+  UnregisterHotkey();
+
+  if (!enabled()) {
+    return;
+  }
+
+  const std::optional<ui::Accelerator> accelerator =
+      AcceleratorFromSettings(shortcut_code(), shortcut_modifiers());
+  if (!accelerator.has_value()) {
+    return;
+  }
+
+  // Portal shortcuts remain registered while the input is focused. The
+  // callback is ignored during capture, avoiding repeated portal sessions.
+  if (listener->IsRegistrationHandledExternally()) {
+    ui::Command command(
+        kCommandId,
+        l10n_util::GetStringUTF16(IDS_BOSS_KEY_COMMAND_DESCRIPTION), true);
+    command.set_accelerator(*accelerator);
+    ui::CommandMap commands;
+    commands.emplace(kCommandId, std::move(command));
+    listener->OnCommandsChanged(
+        kAcceleratorGroupId, kAcceleratorProfileId, commands,
+        gfx::kNullAcceleratedWidget,
+        base::BindRepeating(&BossKeyService::ExecuteCommand,
+                            weak_ptr_factory_.GetWeakPtr()));
+    external_registration_active_ = true;
+    registered_ = true;
+    registered_accelerator_ = *accelerator;
+    return;
+  }
+
+  const bool was_suspended = listener->IsShortcutHandlingSuspended();
+  listener->SetShortcutHandlingSuspended(false);
+  registered_ = listener->RegisterAccelerator(*accelerator, this);
+  listener->SetShortcutHandlingSuspended(was_suspended);
+  if (registered_) {
+    registered_accelerator_ = *accelerator;
+  }
+}
+
+void BossKeyService::UnregisterHotkey() {
+  ui::GlobalAcceleratorListener* listener =
+      ui::GlobalAcceleratorListener::GetInstance();
+  if (!listener) {
+    registered_ = false;
+    external_registration_active_ = false;
+    return;
+  }
+
+  if (external_registration_active_) {
+    listener->OnCommandsChanged(
+        kAcceleratorGroupId, kAcceleratorProfileId, ui::CommandMap(),
+        gfx::kNullAcceleratedWidget,
+        base::BindRepeating(&BossKeyService::ExecuteCommand,
+                            weak_ptr_factory_.GetWeakPtr()));
+    external_registration_active_ = false;
+  } else if (registered_) {
+    listener->UnregisterAccelerator(registered_accelerator_, this);
+  }
+  registered_ = false;
+  registered_accelerator_ = ui::Accelerator();
+}
+
+void BossKeyService::OnKeyPressed(const ui::Accelerator& accelerator) {
+  if (!shortcut_capture_active_ && accelerator == registered_accelerator_) {
+    ToggleBrowsers();
+  }
+}
+
+void BossKeyService::ExecuteCommand(const std::string& accelerator_group_id,
+                                    const std::string& command_id) {
+  if (!shortcut_capture_active_ && accelerator_group_id == kAcceleratorGroupId &&
+      command_id == kCommandId) {
+    ToggleBrowsers();
+  }
+}
+
+void BossKeyService::ToggleBrowsers() {
+  if (windows_hidden_) {
+    RestoreBrowsers();
+  } else {
+    HideBrowsers();
+  }
+}
+
+void BossKeyService::HideBrowsers() {
+  hidden_window_ids_.clear();
+  active_window_id_.reset();
+
+  GlobalBrowserCollection* browsers = GlobalBrowserCollection::GetInstance();
+  if (BrowserWindowInterface* active = browsers->GetActiveBrowser()) {
+    active_window_id_ = active->GetSessionID();
+  }
+  browsers->ForEach([&](BrowserWindowInterface* browser) {
+    ui::BaseWindow* window = browser->GetWindow();
+    if (window && window->IsVisible()) {
+      hidden_window_ids_.push_back(browser->GetSessionID());
+      window->Hide();
+    }
+    return true;
+  });
+
+  if (hidden_window_ids_.empty()) {
+    return;
+  }
+  windows_hidden_ = true;
+  if (mute_browsers()) {
+    MuteBrowserTabs();
+  }
+}
+
+void BossKeyService::RestoreBrowsers() {
+  RestoreBrowserTabs();
+  for (const SessionID& id : hidden_window_ids_) {
+    if (BrowserWindowInterface* browser =
+            BrowserWindowInterface::FromSessionID(id)) {
+      if (ui::BaseWindow* window = browser->GetWindow()) {
+        window->ShowInactive();
+      }
+    }
+  }
+  if (active_window_id_.has_value()) {
+    if (BrowserWindowInterface* browser =
+            BrowserWindowInterface::FromSessionID(*active_window_id_)) {
+      if (ui::BaseWindow* window = browser->GetWindow()) {
+        window->Activate();
+      }
+    }
+  }
+  hidden_window_ids_.clear();
+  active_window_id_.reset();
+  windows_hidden_ = false;
+}
+
+void BossKeyService::MuteBrowserTabs() {
+  muted_tabs_.clear();
+  GlobalBrowserCollection::GetInstance()->ForEach(
+      [&](BrowserWindowInterface* browser) {
+        for (tabs::TabInterface* tab : browser->GetAllTabInterfaces()) {
+          content::WebContents* contents = tab->GetContents();
+          if (!contents) {
+            continue;
+          }
+          muted_tabs_.emplace_back(tab->GetWeakPtr(),
+                                   contents->IsAudioMuted());
+          contents->SetAudioMuted(true);
+        }
+        return true;
+      });
+}
+
+void BossKeyService::RestoreBrowserTabs() {
+  for (MutedTabState& state : muted_tabs_) {
+    if (state.tab) {
+      if (content::WebContents* contents = state.tab->GetContents()) {
+        contents->SetAudioMuted(state.was_muted);
+      }
+    }
+  }
+  muted_tabs_.clear();
+}
+
+}  // namespace boss_key
