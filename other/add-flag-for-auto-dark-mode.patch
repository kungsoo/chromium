+void UpdateGtkAutoDarkModeThemes(ui::NativeTheme* gtk_theme) {
+  static const bool auto_dark_mode =
+      base::CommandLine::ForCurrentProcess()->HasSwitch("auto-dark-mode");
+  if (!auto_dark_mode) {
+    return;
+  }
+
+  const bool use_dark_colors = color_utils::IsDark(GetBgColor(""));
+  const ui::NativeTheme::PreferredColorScheme preferred_color_scheme =
+      use_dark_colors ? ui::NativeTheme::PreferredColorScheme::kDark
+                      : ui::NativeTheme::PreferredColorScheme::kLight;
+
+  auto update_theme = [&](ui::NativeTheme* theme) {
+    const bool changed =
+        theme->preferred_color_scheme() != preferred_color_scheme;
+    theme->set_preferred_color_scheme(preferred_color_scheme);
+    if (changed) {
+      theme->NotifyOnNativeThemeUpdated();
+    }
+  };
+
+  // Chromium 138 updated NativeThemeGtk itself in OnThemeChanged(); keep that
+  // behavior before carrying qcasey's NativeUI/Web force-refresh forward to
+  // Chromium 144's OS settings observer path. Alex313031 gated the original
+  // force-refresh behavior behind --auto-dark-mode.
+  update_theme(gtk_theme);
+
+  ui::NativeTheme* const native_ui_theme =
+      ui::NativeTheme::GetInstanceForNativeUi();
+  if (native_ui_theme != gtk_theme) {
+    update_theme(native_ui_theme);
+  }
+
+  ui::NativeTheme* const web_theme = ui::NativeTheme::GetInstanceForWeb();
+  if (web_theme != gtk_theme && web_theme != native_ui_theme) {
+    update_theme(web_theme);
+  }
+}
+
 }  // namespace
 
 // static
@@ -176,8 +217,14 @@ void NativeThemeGtk::PaintFrameTopArea(
                     rect.x(), rect.y());
 }
 
+void NativeThemeGtk::OnToolkitSettingsChanged(bool force_notify) {
+  ui::NativeTheme::OnToolkitSettingsChanged(force_notify);
+  UpdateGtkAutoDarkModeThemes(this);
+}
+
 NativeThemeGtk::NativeThemeGtk() : NativeThemeBase(ui::SystemTheme::kGtk) {
   BeginObservingOsSettingChanges();
+  UpdateGtkAutoDarkModeThemes(this);
 }
 
 NativeThemeGtk::~NativeThemeGtk() = default;
