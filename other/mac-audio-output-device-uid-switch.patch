+#if BUILDFLAG(IS_MAC)
+void RenderFrameAudioOutputStreamFactory::Core::
+    MacAudioOutputDeviceDescriptionsReceived(
+        base::TimeTicks auth_start_time,
+        mojo::PendingReceiver<media::mojom::AudioOutputStreamProvider> receiver,
+        RequestDeviceAuthorizationCallback callback,
+        const media::AudioParameters& original_params,
+        const std::string& original_raw_device_id,
+        const std::string& device_id_for_renderer,
+        const std::string& preferred_device_uid,
+        media::AudioDeviceDescriptions device_descriptions) {
   DCHECK_CURRENTLY_ON(BrowserThread::IO);
+
+  if (!ContainsOutputDeviceUid(device_descriptions, preferred_device_uid)) {
+    SendLogMessage(base::StringPrintf(
+        "%s => (WARNING: macOS output device UID unavailable, falling back to "
+        "authorized device, {preferred_device_uid=%s}, "
+        "{authorized_device_id=%s})",
+        __func__, preferred_device_uid.c_str(), original_raw_device_id.c_str()));
+    FinishAuthorization(auth_start_time, std::move(receiver),
+                        std::move(callback), media::OUTPUT_DEVICE_STATUS_OK,
+                        original_params, original_raw_device_id,
+                        device_id_for_renderer);
+    return;
+  }
+
+  audio_system_->GetOutputStreamParameters(
+      preferred_device_uid,
+      base::BindOnce(&RenderFrameAudioOutputStreamFactory::Core::
+                         MacAudioOutputDeviceParametersReceived,
+                     weak_ptr_factory_.GetWeakPtr(), auth_start_time,
+                     std::move(receiver), std::move(callback), original_params,
+                     original_raw_device_id, device_id_for_renderer,
+                     preferred_device_uid));
+}
+
+void RenderFrameAudioOutputStreamFactory::Core::
+    MacAudioOutputDeviceParametersReceived(
+        base::TimeTicks auth_start_time,
+        mojo::PendingReceiver<media::mojom::AudioOutputStreamProvider> receiver,
+        RequestDeviceAuthorizationCallback callback,
+        const media::AudioParameters& original_params,
+        const std::string& original_raw_device_id,
+        const std::string& device_id_for_renderer,
+        const std::string& preferred_device_uid,
+        const std::optional<media::AudioParameters>& preferred_params) {
+  DCHECK_CURRENTLY_ON(BrowserThread::IO);
+
+  if (!preferred_params) {
+    SendLogMessage(base::StringPrintf(
+        "%s => (WARNING: macOS output device UID has no valid stream "
+        "parameters, falling back to authorized device, "
+        "{preferred_device_uid=%s}, {authorized_device_id=%s})",
+        __func__, preferred_device_uid.c_str(), original_raw_device_id.c_str()));
+    FinishAuthorization(auth_start_time, std::move(receiver),
+                        std::move(callback), media::OUTPUT_DEVICE_STATUS_OK,
+                        original_params, original_raw_device_id,
+                        device_id_for_renderer);
+    return;
+  }
+
+  SendLogMessage(base::StringPrintf(
+      "%s => (using macOS output device UID, {preferred_device_uid=%s}, "
+      "{authorized_device_id=%s})",
+      __func__, preferred_device_uid.c_str(), original_raw_device_id.c_str()));
+  FinishAuthorization(auth_start_time, std::move(receiver), std::move(callback),
+                      media::OUTPUT_DEVICE_STATUS_OK, *preferred_params,
+                      preferred_device_uid, device_id_for_renderer);
+}
+#endif  // BUILDFLAG(IS_MAC)
