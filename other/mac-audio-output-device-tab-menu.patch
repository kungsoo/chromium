+// Returns the browser-wide macOS output device UID selected at runtime, falling
+// back to the --mac-audio-output-device-uid command-line switch when no runtime
+// selection has been made. An empty string means System Default.
+MEDIA_EXPORT std::string GetMacAudioOutputDeviceUid();
