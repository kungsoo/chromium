diff --git a/chrome/browser/ui/tabs/mac_audio_output_device_sub_menu_model.cc b/chrome/browser/ui/tabs/mac_audio_output_device_sub_menu_model.cc
new file mode 100644
index 0000000..eb27422
--- /dev/null
+++ b/chrome/browser/ui/tabs/mac_audio_output_device_sub_menu_model.cc
@@ -0,0 +1,241 @@
+// Copyright 2026 The Chromium Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "chrome/browser/ui/tabs/mac_audio_output_device_sub_menu_model.h"
+
+#include <CoreAudio/CoreAudio.h>
+
+#include <algorithm>
+#include <optional>
+#include <string>
+#include <vector>
+
+#include "base/apple/scoped_cftyperef.h"
+#include "base/strings/sys_string_conversions.h"
+#include "base/strings/utf_string_conversions.h"
+#include "content/public/browser/mac_audio_output_device.h"
+#include "content/public/browser/media_session.h"
+
+namespace {
+
+constexpr size_t kMaxAudioOutputDeviceCount =
+    MacAudioOutputDeviceSubMenuModel::kMaxAudioOutputDeviceCommandId -
+    MacAudioOutputDeviceSubMenuModel::kMinAudioOutputDeviceCommandId + 1;
+
+std::optional<std::string> GetStringProperty(
+    AudioObjectID object_id,
+    AudioObjectPropertySelector selector,
+    AudioObjectPropertyScope scope) {
+  AudioObjectPropertyAddress address = {selector, scope,
+                                        kAudioObjectPropertyElementMain};
+
+  CFStringRef property_value = nullptr;
+  UInt32 size = sizeof(property_value);
+  OSStatus result = AudioObjectGetPropertyData(object_id, &address, 0, nullptr,
+                                               &size, &property_value);
+  if (result != noErr || !property_value) {
+    return std::nullopt;
+  }
+
+  base::apple::ScopedCFTypeRef<CFStringRef> scoped_property_value(
+      property_value);
+  return base::SysCFStringRefToUTF8(scoped_property_value.get());
+}
+
+std::optional<std::string> GetDeviceName(AudioObjectID device_id) {
+  std::optional<std::string> name = GetStringProperty(
+      device_id, kAudioObjectPropertyName, kAudioObjectPropertyScopeGlobal);
+  if (name) {
+    return name;
+  }
+
+  // Fall back to the legacy device-name property for devices that do not
+  // expose the modern kAudioObjectPropertyName selector.
+  return GetStringProperty(device_id, kAudioDevicePropertyDeviceNameCFString,
+                           kAudioObjectPropertyScopeOutput);
+}
+
+std::optional<std::string> GetDeviceUid(AudioObjectID device_id) {
+  return GetStringProperty(device_id, kAudioDevicePropertyDeviceUID,
+                           kAudioObjectPropertyScopeGlobal);
+}
+
+std::vector<AudioObjectID> GetAllAudioDeviceIds() {
+  AudioObjectPropertyAddress address = {kAudioHardwarePropertyDevices,
+                                        kAudioObjectPropertyScopeGlobal,
+                                        kAudioObjectPropertyElementMain};
+
+  UInt32 size = 0;
+  OSStatus result = AudioObjectGetPropertyDataSize(kAudioObjectSystemObject,
+                                                   &address, 0, nullptr, &size);
+  if (result != noErr || size == 0) {
+    return {};
+  }
+
+  std::vector<AudioObjectID> device_ids(size / sizeof(AudioObjectID));
+  if (device_ids.empty()) {
+    return {};
+  }
+
+  result = AudioObjectGetPropertyData(kAudioObjectSystemObject, &address, 0,
+                                      nullptr, &size, device_ids.data());
+  if (result != noErr) {
+    return {};
+  }
+
+  device_ids.resize(size / sizeof(AudioObjectID));
+  return device_ids;
+}
+
+bool HasOutputStreams(AudioObjectID device_id) {
+  AudioObjectPropertyAddress address = {kAudioDevicePropertyStreams,
+                                        kAudioObjectPropertyScopeOutput,
+                                        kAudioObjectPropertyElementMain};
+
+  UInt32 size = 0;
+  OSStatus result =
+      AudioObjectGetPropertyDataSize(device_id, &address, 0, nullptr, &size);
+  return result == noErr && size > 0;
+}
+
+}  // namespace
+
+MacAudioOutputDeviceSubMenuModel::MacAudioOutputDeviceSubMenuModel(
+    content::WebContents* web_contents)
+    : ui::SimpleMenuModel(this),
+      web_contents_(web_contents),
+      devices_(EnumerateAudioOutputDevices()),
+      selected_device_uid_(
+          content::GetMacAudioOutputDeviceUidForWebContents(web_contents)
+              .value_or(std::string())) {
+  if (devices_.size() > kMaxAudioOutputDeviceCount) {
+    devices_.resize(kMaxAudioOutputDeviceCount);
+  }
+
+  AddCheckItem(kSystemDefaultCommandId, u"System Default");
+  for (size_t i = 0; i < devices_.size(); ++i) {
+    AddCheckItem(kMinAudioOutputDeviceCommandId + i,
+                 base::UTF8ToUTF16(devices_[i].name));
+  }
+}
+
+MacAudioOutputDeviceSubMenuModel::~MacAudioOutputDeviceSubMenuModel() = default;
+
+bool MacAudioOutputDeviceSubMenuModel::IsCommandIdChecked(
+    int command_id) const {
+  const bool selected_device_available = IsSelectedDeviceAvailable();
+  if (command_id == kSystemDefaultCommandId) {
+    return selected_device_uid_.empty() || !selected_device_available;
+  }
+
+  const AudioOutputDevice* device = GetDeviceForCommandId(command_id);
+  return device && selected_device_available &&
+         device->uid == selected_device_uid_;
+}
+
+bool MacAudioOutputDeviceSubMenuModel::IsCommandIdEnabled(
+    int command_id) const {
+  return command_id == kSystemDefaultCommandId ||
+         GetDeviceForCommandId(command_id);
+}
+
+void MacAudioOutputDeviceSubMenuModel::ExecuteCommand(int command_id,
+                                                      int /*event_flags*/) {
+  if (command_id == kSystemDefaultCommandId) {
+    selected_device_uid_.clear();
+    content::ClearMacAudioOutputDeviceUidForWebContents(web_contents_);
+    SwitchActiveMediaSessionAudioOutput();
+    return;
+  }
+
+  AudioOutputDevice* device = GetDeviceForCommandId(command_id);
+  if (!device) {
+    return;
+  }
+
+  const std::string device_uid = device->uid;
+  if (!ContainsDeviceUid(EnumerateAudioOutputDevices(), device_uid)) {
+    selected_device_uid_.clear();
+    content::ClearMacAudioOutputDeviceUidForWebContents(web_contents_);
+    SwitchActiveMediaSessionAudioOutput();
+    return;
+  }
+
+  selected_device_uid_ = device_uid;
+  content::SetMacAudioOutputDeviceUidForWebContents(web_contents_, device_uid);
+  SwitchActiveMediaSessionAudioOutput();
+}
+
+// static
+std::vector<MacAudioOutputDeviceSubMenuModel::AudioOutputDevice>
+MacAudioOutputDeviceSubMenuModel::EnumerateAudioOutputDevices() {
+  std::vector<AudioOutputDevice> devices;
+  for (AudioObjectID device_id : GetAllAudioDeviceIds()) {
+    if (!HasOutputStreams(device_id)) {
+      continue;
+    }
+
+    std::optional<std::string> name = GetDeviceName(device_id);
+    std::optional<std::string> uid = GetDeviceUid(device_id);
+    if (!name || name->empty() || !uid || uid->empty() ||
+        ContainsDeviceUid(devices, *uid)) {
+      continue;
+    }
+
+    devices.push_back({std::move(*name), std::move(*uid)});
+  }
+  return devices;
+}
+
+bool MacAudioOutputDeviceSubMenuModel::IsSelectedDeviceAvailable() const {
+  return !selected_device_uid_.empty() &&
+         ContainsDeviceUid(selected_device_uid_);
+}
+
+// static
+bool MacAudioOutputDeviceSubMenuModel::ContainsDeviceUid(
+    const std::vector<AudioOutputDevice>& devices,
+    const std::string& device_uid) {
+  return std::ranges::any_of(
+      devices, [&](const auto& device) { return device.uid == device_uid; });
+}
+
+bool MacAudioOutputDeviceSubMenuModel::ContainsDeviceUid(
+    const std::string& device_uid) const {
+  return ContainsDeviceUid(devices_, device_uid);
+}
+
+void MacAudioOutputDeviceSubMenuModel::SwitchActiveMediaSessionAudioOutput()
+    const {
+  if (!web_contents_) {
+    return;
+  }
+
+  const std::string effective_device_uid =
+      content::GetEffectiveMacAudioOutputDeviceUid(web_contents_);
+  content::MediaSession::Get(web_contents_)
+      ->SetAudioSinkId(effective_device_uid.empty()
+                           ? std::nullopt
+                           : std::make_optional(effective_device_uid));
+}
+
+MacAudioOutputDeviceSubMenuModel::AudioOutputDevice*
+MacAudioOutputDeviceSubMenuModel::GetDeviceForCommandId(int command_id) {
+  if (command_id < kMinAudioOutputDeviceCommandId ||
+      command_id > kMaxAudioOutputDeviceCommandId) {
+    return nullptr;
+  }
+
+  size_t device_index = command_id - kMinAudioOutputDeviceCommandId;
+  if (device_index >= devices_.size()) {
+    return nullptr;
+  }
+  return &devices_[device_index];
+}
+
+const MacAudioOutputDeviceSubMenuModel::AudioOutputDevice*
+MacAudioOutputDeviceSubMenuModel::GetDeviceForCommandId(int command_id) const {
+  return const_cast<MacAudioOutputDeviceSubMenuModel*>(this)
+      ->GetDeviceForCommandId(command_id);
+}
