+
+class MacAudioOutputDeviceSubMenuModel : public ui::SimpleMenuModel,
+                                         public ui::SimpleMenuModel::Delegate {
+ public:
+  explicit MacAudioOutputDeviceSubMenuModel(content::WebContents* web_contents);
+  MacAudioOutputDeviceSubMenuModel(const MacAudioOutputDeviceSubMenuModel&) =
+      delete;
+  MacAudioOutputDeviceSubMenuModel& operator=(
+      const MacAudioOutputDeviceSubMenuModel&) = delete;
+  ~MacAudioOutputDeviceSubMenuModel() override;
+
+  // Command IDs used by the parent tab context menu and this submenu.
+  static constexpr int kSubMenuCommandId = 1900;
+  static constexpr int kSystemDefaultCommandId = 1901;
+  static constexpr int kMinAudioOutputDeviceCommandId = 1902;
+  static constexpr int kMaxAudioOutputDeviceCommandId = 2199;
+
+ private:
+  struct AudioOutputDevice {
+    std::string name;
+    std::string uid;
+  };
+
+  // ui::SimpleMenuModel::Delegate:
+  bool IsCommandIdChecked(int command_id) const override;
+  bool IsCommandIdEnabled(int command_id) const override;
+  void ExecuteCommand(int command_id, int event_flags) override;
+
+  static std::vector<AudioOutputDevice> EnumerateAudioOutputDevices();
+  static bool ContainsDeviceUid(const std::vector<AudioOutputDevice>& devices,
+                                const std::string& device_uid);
+
+  bool IsSelectedDeviceAvailable() const;
+  bool ContainsDeviceUid(const std::string& device_uid) const;
+  void SwitchActiveMediaSessionAudioOutput() const;
+  AudioOutputDevice* GetDeviceForCommandId(int command_id);
+  const AudioOutputDevice* GetDeviceForCommandId(int command_id) const;
+
+  raw_ptr<content::WebContents> web_contents_;
+  std::vector<AudioOutputDevice> devices_;
+  std::string selected_device_uid_;
+};
+
+#endif  // CHROME_BROWSER_UI_TABS_MAC_AUDIO_OUTPUT_DEVICE_SUB_MENU_MODEL_H_
