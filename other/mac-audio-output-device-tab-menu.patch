diff --git a/media/base/mac_audio_output_device_uid.cc b/media/base/mac_audio_output_device_uid.cc
new file mode 100644
index 0000000..cdf11a0
--- /dev/null
+++ b/media/base/mac_audio_output_device_uid.cc
@@ -0,0 +1,66 @@
+// Copyright 2026 The Chromium Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "media/base/mac_audio_output_device_uid.h"
+
+#include <optional>
+#include <string>
+#include <utility>
+
+#include "base/command_line.h"
+#include "base/no_destructor.h"
+#include "base/synchronization/lock.h"
+#include "base/thread_annotations.h"
+#include "media/base/media_switches.h"
+
+namespace media {
+
+namespace {
+
+struct MacAudioOutputDeviceUidState {
+  base::Lock lock;
+  std::optional<std::string> runtime_device_uid GUARDED_BY(lock);
+};
+
+MacAudioOutputDeviceUidState& GetState() {
+  static base::NoDestructor<MacAudioOutputDeviceUidState> state;
+  return *state;
+}
+
+std::string GetMacAudioOutputDeviceUidSwitchValue() {
+  const base::CommandLine* command_line =
+      base::CommandLine::ForCurrentProcess();
+  if (!command_line->HasSwitch(switches::kMacAudioOutputDeviceUid)) {
+    return std::string();
+  }
+  return command_line->GetSwitchValueUTF8(switches::kMacAudioOutputDeviceUid);
+}
+
+}  // namespace
+
+std::string GetMacAudioOutputDeviceUid() {
+  MacAudioOutputDeviceUidState& state = GetState();
+  {
+    base::AutoLock lock(state.lock);
+    if (state.runtime_device_uid.has_value()) {
+      return *state.runtime_device_uid;
+    }
+  }
+
+  return GetMacAudioOutputDeviceUidSwitchValue();
+}
+
+void SetMacAudioOutputDeviceUid(std::string device_uid) {
+  MacAudioOutputDeviceUidState& state = GetState();
+  base::AutoLock lock(state.lock);
+  state.runtime_device_uid = std::move(device_uid);
+}
+
+void ClearMacAudioOutputDeviceUidForTesting() {
+  MacAudioOutputDeviceUidState& state = GetState();
+  base::AutoLock lock(state.lock);
+  state.runtime_device_uid.reset();
+}
+
+}  // namespace media
