+
+#ifndef CONTENT_PUBLIC_BROWSER_MAC_AUDIO_OUTPUT_DEVICE_H_
+#define CONTENT_PUBLIC_BROWSER_MAC_AUDIO_OUTPUT_DEVICE_H_
+
+#include <optional>
+#include <string>
+
+#include "content/common/content_export.h"
+
+namespace content {
+
+struct GlobalRenderFrameHostToken;
+class WebContents;
+
+// Returns the explicit macOS audio output device UID selected for
+// `web_contents`, or nullopt when the tab uses System Default.
+CONTENT_EXPORT std::optional<std::string>
+GetMacAudioOutputDeviceUidForWebContents(WebContents* web_contents);
+
+// Returns the effective macOS audio output device UID for `web_contents`.
+// Per-tab selection wins; otherwise this falls back to the browser-wide runtime
+// selection and then the --mac-audio-output-device-uid command-line switch. An
+// empty string means Chromium's normal system-default behavior.
+CONTENT_EXPORT std::string GetEffectiveMacAudioOutputDeviceUid(
+    WebContents* web_contents);
+
+// Returns the effective macOS audio output device UID for the frame tree rooted
+// at `main_frame_token`. This is safe to call from the IO thread during audio
+// stream authorization.
+CONTENT_EXPORT std::string GetEffectiveMacAudioOutputDeviceUid(
+    const GlobalRenderFrameHostToken& main_frame_token);
+
+// Sets the explicit per-tab macOS audio output device UID. Passing an empty UID
+// clears the per-tab override and selects System Default for the tab.
+CONTENT_EXPORT void SetMacAudioOutputDeviceUidForWebContents(
+    WebContents* web_contents,
+    std::string device_uid);
+
+// Clears the explicit per-tab macOS audio output device UID.
+CONTENT_EXPORT void ClearMacAudioOutputDeviceUidForWebContents(
+    WebContents* web_contents);
+
+}  // namespace content
+
+#endif  // CONTENT_PUBLIC_BROWSER_MAC_AUDIO_OUTPUT_DEVICE_H_
