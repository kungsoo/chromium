diff --git a/content/public/browser/mac_audio_output_device.cc b/content/public/browser/mac_audio_output_device.cc
new file mode 100644
index 0000000..4c73f3f
--- /dev/null
+++ b/content/public/browser/mac_audio_output_device.cc
@@ -0,0 +1,207 @@
+// Copyright 2026 The Chromium Authors
+// Use of this source code is governed by a BSD-style license that can be
+// found in the LICENSE file.
+
+#include "content/public/browser/mac_audio_output_device.h"
+
+#include <map>
+#include <optional>
+#include <string>
+#include <utility>
+
+#include "base/no_destructor.h"
+#include "base/synchronization/lock.h"
+#include "base/thread_annotations.h"
+#include "content/public/browser/global_routing_id.h"
+#include "content/public/browser/page.h"
+#include "content/public/browser/render_frame_host.h"
+#include "content/public/browser/web_contents.h"
+#include "content/public/browser/web_contents_observer.h"
+#include "content/public/browser/web_contents_user_data.h"
+#include "media/base/mac_audio_output_device_uid.h"
+
+namespace content {
+
+namespace {
+
+// Per-tab device selection is owned on the UI thread by the WebContents user
+// data below. Audio stream authorization runs on the IO thread, where only a
+// GlobalRenderFrameHostToken is available, so the UI-thread state mirrors each
+// selection into this global, lock-guarded token->UID map. The map is the
+// thread-safe bridge the IO thread reads; the WebContents state is the truth.
+struct MacAudioOutputDeviceTabState {
+  base::Lock lock;
+  std::map<GlobalRenderFrameHostToken, std::string> device_uids
+      GUARDED_BY(lock);
+};
+
+MacAudioOutputDeviceTabState& GetTabState() {
+  static base::NoDestructor<MacAudioOutputDeviceTabState> state;
+  return *state;
+}
+
+std::optional<std::string> GetTabDeviceUid(
+    const GlobalRenderFrameHostToken& main_frame_token) {
+  MacAudioOutputDeviceTabState& state = GetTabState();
+  base::AutoLock lock(state.lock);
+  auto it = state.device_uids.find(main_frame_token);
+  if (it == state.device_uids.end()) {
+    return std::nullopt;
+  }
+  return it->second;
+}
+
+void SetTabDeviceUid(const GlobalRenderFrameHostToken& main_frame_token,
+                     const std::string& device_uid) {
+  MacAudioOutputDeviceTabState& state = GetTabState();
+  base::AutoLock lock(state.lock);
+  state.device_uids[main_frame_token] = device_uid;
+}
+
+void ClearTabDeviceUid(const GlobalRenderFrameHostToken& main_frame_token) {
+  MacAudioOutputDeviceTabState& state = GetTabState();
+  base::AutoLock lock(state.lock);
+  state.device_uids.erase(main_frame_token);
+}
+
+class MacAudioOutputDeviceWebContentsState
+    : public WebContentsObserver,
+      public WebContentsUserData<MacAudioOutputDeviceWebContentsState> {
+ public:
+  ~MacAudioOutputDeviceWebContentsState() override {
+    UnregisterMainFrameToken();
+  }
+
+  const std::optional<std::string>& device_uid() const { return device_uid_; }
+
+  void SetDeviceUid(std::string device_uid) {
+    if (device_uid.empty()) {
+      ClearDeviceUid();
+      return;
+    }
+
+    device_uid_ = std::move(device_uid);
+    RegisterCurrentMainFrameToken();
+  }
+
+  void ClearDeviceUid() {
+    device_uid_.reset();
+    UnregisterMainFrameToken();
+  }
+
+ private:
+  friend class WebContentsUserData<MacAudioOutputDeviceWebContentsState>;
+
+  explicit MacAudioOutputDeviceWebContentsState(WebContents* web_contents)
+      : WebContentsObserver(web_contents),
+        WebContentsUserData<MacAudioOutputDeviceWebContentsState>(
+            *web_contents) {}
+
+  void PrimaryPageChanged(Page& page) override {
+    RegisterCurrentMainFrameToken();
+  }
+
+  void WebContentsDestroyed() override { UnregisterMainFrameToken(); }
+
+  void RegisterCurrentMainFrameToken() {
+    if (!device_uid_) {
+      UnregisterMainFrameToken();
+      return;
+    }
+
+    WebContents* contents = web_contents();
+    if (!contents) {
+      UnregisterMainFrameToken();
+      return;
+    }
+
+    RenderFrameHost* main_frame = contents->GetPrimaryMainFrame();
+    if (!main_frame) {
+      UnregisterMainFrameToken();
+      return;
+    }
+
+    const GlobalRenderFrameHostToken main_frame_token =
+        main_frame->GetGlobalFrameToken();
+    if (main_frame_token_ && *main_frame_token_ != main_frame_token) {
+      ClearTabDeviceUid(*main_frame_token_);
+    }
+
+    main_frame_token_ = main_frame_token;
+    SetTabDeviceUid(*main_frame_token_, *device_uid_);
+  }
+
+  void UnregisterMainFrameToken() {
+    if (!main_frame_token_) {
+      return;
+    }
+    ClearTabDeviceUid(*main_frame_token_);
+    main_frame_token_.reset();
+  }
+
+  std::optional<std::string> device_uid_;
+  std::optional<GlobalRenderFrameHostToken> main_frame_token_;
+
+  WEB_CONTENTS_USER_DATA_KEY_DECL();
+};
+
+WEB_CONTENTS_USER_DATA_KEY_IMPL(MacAudioOutputDeviceWebContentsState);
+
+}  // namespace
+
+std::optional<std::string> GetMacAudioOutputDeviceUidForWebContents(
+    WebContents* web_contents) {
+  if (!web_contents) {
+    return std::nullopt;
+  }
+
+  const auto* state =
+      MacAudioOutputDeviceWebContentsState::FromWebContents(web_contents);
+  if (!state) {
+    return std::nullopt;
+  }
+  return state->device_uid();
+}
+
+std::string GetEffectiveMacAudioOutputDeviceUid(WebContents* web_contents) {
+  std::optional<std::string> tab_device_uid =
+      GetMacAudioOutputDeviceUidForWebContents(web_contents);
+  if (tab_device_uid) {
+    return *tab_device_uid;
+  }
+  return media::GetMacAudioOutputDeviceUid();
+}
+
+std::string GetEffectiveMacAudioOutputDeviceUid(
+    const GlobalRenderFrameHostToken& main_frame_token) {
+  std::optional<std::string> tab_device_uid = GetTabDeviceUid(main_frame_token);
+  if (tab_device_uid) {
+    return *tab_device_uid;
+  }
+  return media::GetMacAudioOutputDeviceUid();
+}
+
+void SetMacAudioOutputDeviceUidForWebContents(WebContents* web_contents,
+                                              std::string device_uid) {
+  if (!web_contents) {
+    return;
+  }
+
+  MacAudioOutputDeviceWebContentsState::GetOrCreateForWebContents(web_contents)
+      ->SetDeviceUid(std::move(device_uid));
+}
+
+void ClearMacAudioOutputDeviceUidForWebContents(WebContents* web_contents) {
+  if (!web_contents) {
+    return;
+  }
+
+  auto* state =
+      MacAudioOutputDeviceWebContentsState::FromWebContents(web_contents);
+  if (!state) {
+    return;
+  }
+  state->ClearDeviceUid();
+}
+
+}  // namespace content
