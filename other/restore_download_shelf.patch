+float GetDPIScaleForView(views::View* view) {
+  DCHECK(display::Screen::HasScreen());
+  return display::Screen::Get()
+      ->GetPreferredScaleFactorForView(view->GetWidget()->GetNativeView())
+      .value_or(1.0f);
+}
