+gfx::Rect BrowserViewLayoutImpl::LayoutDownloadShelf(
+    ProposedLayout& layout,
+    gfx::Rect available_bounds) const {
+  if (!IsParentedTo(views().download_shelf, views().browser_view)) {
+    return available_bounds;
+  }
+
+  gfx::Rect shelf_bounds;
+  const bool visible = views().download_shelf->GetVisible();
+  if (visible) {
+    const int shelf_height = std::min(
+        views().download_shelf->GetPreferredSize().height(),
+        available_bounds.height());
+    shelf_bounds =
+        gfx::Rect(available_bounds.x(), available_bounds.bottom() - shelf_height,
+                  available_bounds.width(), shelf_height);
+    available_bounds.set_height(available_bounds.height() - shelf_height);
+  }
+  layout.AddChild(views().download_shelf, shelf_bounds, visible);
+  return available_bounds;
+}
